# =============================================
# MatchGoal - Variáveis de ambiente (exemplo)
# Copie para apps/app/.env.local e preencha os valores reais.
# NUNCA commite arquivos .env reais.
# =============================================

# --- Supabase (banco de dados + auth) ---
# Painel do Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # NUNCA expor client-side

# --- Abacate Pay ---
# Painel da Abacate > Integração > Webhooks — o secret que você define
ABACATE_WEBHOOK_SECRET=
# Painel da Abacate > Integração > API
ABACATE_API_KEY=
# Opcional: "true" para bloquear pagamentos de TESTE (devMode) em produção
ABACATE_BLOCK_DEV_MODE=

# --- Kiwify ---
# Painel da Kiwify > Webhooks > Token (cole também na URL do webhook: ?token=)
KIWIFY_WEBHOOK_TOKEN=

# --- Cron job (renovações diárias) ---
# String aleatória (ex: openssl rand -hex 32) — usada para proteger /api/cron/renewals
CRON_SECRET=

# --- Painel /admin (ativação manual de assinatura) ---
# Email da conta Supabase autorizada a acessar /admin
ADMIN_EMAIL=

# --- Email transacional (Resend) ---
# resend.com > API Keys
RESEND_API_KEY=

# --- URL pública do app ---
# Em produção: https://app.matchgoal.com.br | Em dev: http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Email transacional (remetente) ---
# Remetente dos emails de acesso (o domínio precisa estar VERIFICADO na Resend).
EMAIL_FROM="MatchGoal <noreply@matchgoal.com.br>"

# --- Dev local (preview) ---
# Sem Supabase configurado, o app fica BLOQUEADO (paywall, igual produção).
# Defina como "true" SÓ em dev para liberar as análises e visualizar o app sem
# backend. Nunca tem efeito em produção (trava por NODE_ENV=production).
NEXT_PUBLIC_DEV_UNLOCK=

# --- APIs externas ---
# API-Football (API-Sports v3) — dados reais da Copa 2026.
# Crie uma chave grátis em https://www.api-football.com (100 req/dia).
# API_FOOTBALL_KEY=
