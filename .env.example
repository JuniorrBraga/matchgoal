# =============================================
# MatchGoal - Variáveis de ambiente (exemplo)
# Copie para apps/app/.env.local e preencha os valores reais.
# NUNCA commite arquivos .env reais.
# =============================================

# --- Supabase (banco de dados + auth) ---
# Painel do Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # NUNCA expor client-side

# --- Abacate Pay ---
# Painel da Abacate > Integração > Webhooks — o secret que você define
ABACATE_WEBHOOK_SECRET=
# Painel da Abacate > Integração > API
ABACATE_API_KEY=

# --- Cron job (renovações diárias) ---
# String aleatória (ex: openssl rand -hex 32) — usada para proteger /api/cron/renewals
CRON_SECRET=

# --- Email transacional (Resend) ---
# resend.com > API Keys
RESEND_API_KEY=

# --- URL pública do app ---
# Em produção: https://app.matchgoal.com.br | Em dev: http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
