# =============================================
# MatchGoal - Variáveis de ambiente (exemplo)
# Copie para .env.local em cada app conforme necessário.
# NUNCA commite arquivos .env reais.
# =============================================

# --- Banco de dados (placeholder) ---
# DATABASE_URL=

# --- Autenticação (placeholder) ---
# AUTH_SECRET=

# --- APIs externas ---
# API-Football (API-Sports v3) — dados reais da Copa 2026.
# Crie uma chave grátis em https://www.api-football.com (100 req/dia).
# Sem esta chave, o app roda com dados mockados.
# API_FOOTBALL_KEY=

# EXTERNAL_API_KEY=

# --- Supabase ---
# Projeto do MatchGoal (schema isolado "matchgoal"). URL e anon/publishable
# key não são secretas; a service_role key (secreta) só no backend.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_DB_SCHEMA=matchgoal
# SUPABASE_SERVICE_ROLE_KEY=   # secreta — apenas no servidor

# --- Pagamentos (placeholder) ---
# PAYMENT_SECRET_KEY=
